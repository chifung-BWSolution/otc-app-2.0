      "default": "\u5f85\u5be9\u6279"
    },
    "reviewed_by": {
      "type": "string",
      "title": "\u5be9\u6279\u4eba"
    },
    "reviewed_at": {
      "type": "string",
      "title": "\u5be9\u6279\u6642\u9593",
      "format": "date-time"
    },
    "review_note": {
      "type": "string",
      "title": "\u5be9\u6279\u5099\u8a3b"

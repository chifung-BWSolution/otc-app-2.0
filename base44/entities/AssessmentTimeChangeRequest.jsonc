      "type": "string",
      "title": "\u7533\u8acb\u4eba\u59d3\u540d"
    },
    "current_date": {
      "type": "string",
      "title": "\u7576\u524d\u8003\u6838\u6642\u9593",
      "format": "date-time"
    },
    "requested_date": {
      "type": "string",
      "title": "\u671f\u671b\u8003\u6838\u6642\u9593",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "title": "\u4fee\u6539\u539f\u56e0"
    },
    "status": {
      "type": "string",
      "title": "\u5be9\u6279\u72c0\u614b",

        "\u54fa\u4e73\u5047"
      ]
    },
    "from_date": {
      "type": "string",
      "title": "\u958b\u59cb\u65e5\u671f",
      "format": "date"
    },
    "to_date": {
      "type": "string",
      "title": "\u7d50\u675f\u65e5\u671f",
      "format": "date"
    },
    "days": {
      "type": "number",
      "title": "\u5929\u6578"
    },

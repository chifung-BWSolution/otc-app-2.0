      "items": {
        "type": "string"
      }
    },
    "pushed_as_resource": {
      "type": "boolean",
      "title": "\u5df2\u63a8\u9001\u70ba\u8ab2\u7a0b\u8cc7\u6e90",
      "default": false
    }
  },
  "required": [
    "title",
    "content",
    "user_email",
    "week_start",
    "status"
  ]
}
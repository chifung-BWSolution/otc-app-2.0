      "type": "string",
      "title": "\u9078\u9805 1"
    },
    "option_2": {
      "type": "string",
      "title": "\u9078\u9805 2"
    },
    "option_3": {
      "type": "string",
      "title": "\u9078\u9805 3"
    },
    "option_4": {
      "type": "string",
      "title": "\u9078\u9805 4"
    },
    "is_option": {
      "type": "boolean",
      "title": "\u662f\u5426\u9078\u9805\u984c",
      "default": false
    },
    "is_required": {
      "type": "boolean",
      "title": "\u5fc5\u586b",
      "default": false
